{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "isAdmin", "createdAt"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "countInStock": { "type": "number" }
      },
      "required": ["id", "name", "price", "category", "countInStock"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "state": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" }
      },
      "required": ["id", "customerName", "phone", "state", "status", "totalAmount"]
    },
    "DeliveryTariff": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DeliveryTariff",
      "type": "object",
      "properties": {
        "stateName": { "type": "string" },
        "homePrice": { "type": "number" },
        "deskPrice": { "type": "number" }
      },
      "required": ["stateName", "homePrice", "deskPrice"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store inventory."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    },
    "/delivery_tariffs/{stateId}": {
      "schema": { "$ref": "#/entities/DeliveryTariff" },
      "description": "Shipping costs by region."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Admin privileges marker."
    }
  }
}