rules_version = '2';

/**
 * PixelCart Firestore Security Rules
 *
 * This ruleset implements a robust, multi-layered security model. 
 * It prioritizes path-based ownership for user-specific data and a 
 * Role-Based Access Control (RBAC) system for administrative functions.
 * It also explicitly recognizes the Super Admin UID for system setup.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user is an admin.
     * Recognized via hardcoded Super Admin UID or role in roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "cgeNA9jvuCeC42zZV4EcntT21Jw2" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /** Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isAdmin();

      match /cart/{cartId} {
        allow read, write: if isOwner(userId);
        
        match /cartItems/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    /**
     * @description Global product catalog. Publicly readable, admin-only writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Product categories. Publicly readable, admin-only writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Delivery tariffs per wilaya. Publicly readable, admin-only writes.
     */
    match /delivery_tariffs/{stateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Site global settings. Publicly readable, admin-only writes.
     */
    match /settings/{docId} {
      allow get: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Orders placed by customers. Public creation, admin-only management.
     */
    match /orders/{orderId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    /**
     * @description Role lookup collection.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}